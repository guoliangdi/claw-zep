# ================================================
# claw-zep 环境配置模板
# 复制为 .env 并填写实际值
# ================================================

# --- 应用基础配置 ---
APP_NAME=claw-zep
APP_ENV=development           # development | production | testing
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# --- JWT配置 ---
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claw_zep
POSTGRES_USER=claw_zep_user
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# --- Celery ---
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# --- 存储后端开关 ---
# kuzu_chroma：旧后端（Kuzu 图 + Chroma 向量，多服务）
# postgres   ：新后端（单 PostgreSQL：Apache AGE 图 + pgvector 向量）
STORAGE_BACKEND=postgres

# --- PostgreSQL 图谱/向量扩展（STORAGE_BACKEND=postgres 时生效）---
AGE_ENABLED=true                 # AGE 图加速；不可用自动回退纯 SQL 递归 CTE
AGE_GRAPH_NAME=claw_graph
PGVECTOR_ENABLED=true            # pgvector 向量索引；不可用回退内存余弦
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64

# --- Kuzu 图数据库（旧后端 kuzu_chroma）---
KUZU_DB_PATH=./data/kuzu_db
KUZU_MAX_DB_SIZE_GB=10

# --- Chroma 向量数据库（旧后端 kuzu_chroma）---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chroma_db

# --- 对象存储 (MinIO/S3兼容) ---
OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=claw-zep-memory-tree
OBJECT_STORAGE_USE_SSL=false

# --- LLM 配置 ---
# 主力LLM（实体抽取、摘要生成）
LLM_PROVIDER=openai           # openai | anthropic | ollama | zhipu | qwen
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Embedding模型
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- 多租户默认配置 ---
DEFAULT_TENANT_MAX_PROJECTS=10
DEFAULT_TENANT_MAX_USERS=50
DEFAULT_TENANT_MAX_MEMORY_MB=1024
SUPER_ADMIN_EMAIL=admin@claw-zep.com
SUPER_ADMIN_PASSWORD=Admin@123456

# --- 限流配置 ---
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:80"]
CORS_ALLOW_CREDENTIALS=true

# --- 审计日志 ---
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# --- Graphiti 扩展配置 ---
GRAPHITI_ENTITY_EXTRACTION_ENABLED=true
GRAPHITI_RELATION_EXTRACTION_ENABLED=true
GRAPHITI_MAX_EPISODE_BATCH=50

# --- 记忆树配置 ---
MEMORY_TREE_SOURCE_MAX_DEPTH=5
MEMORY_TREE_TOPIC_MAX_NODES=200
MEMORY_TREE_GLOBAL_SUMMARY_INTERVAL_HOURS=24
MEMORY_TREE_MARKDOWN_EXPORT_PATH=./data/memory_tree_exports
